# QuickRent Environment Variables Example
# Copy this file to .env and fill in the values

# Flask Configuration
SECRET_KEY=dev-secret-key-change-this-in-production
FLASK_APP=run.py
FLASK_DEBUG=1

# Database Configuration
# Local SQLite for development:
DATABASE_URI=sqlite:///quickrent.db

# Supabase PostgreSQL for production (example):
# DATABASE_URI=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# WhatsApp Configuration (if needed for API keys)
# WHATSAPP_API_KEY=your_key_here
